<%= turbo_frame_tag "#{dom_id(chat)}_message_form" do %>
  <%= form_with(model: Message.new, url: [chat, chat.messages.new]) do |form| %>
    <div>
      <%= form.text_area :content, rows: 4, autofocus: true, "x-on:keydown.cmd.enter" => "$event.target.form.requestSubmit();" %>
    </div>

    <div>
      <%= form.button type: :submit do %>
        <span>Send</span>
      <% end %>
    </div>
  <% end %>
<% end %>
